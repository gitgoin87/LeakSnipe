# Copy to .env in this folder (repo root: LeakSnipe/.env). Never commit .env.
# Restart LeakSnipe after editing (close app and run Launch-LeakSnipe.bat again).

# ── Default AI: Ollama (local, no API key) ─────────────────────────────────────
# 1. Install: https://ollama.com/download
# 2. Keep the Ollama app running (or run: ollama serve)
# 3. Pull a model (recommended for hand analysis):
#       ollama pull deepseek-r1:8b
#    Smaller / faster alternatives:
#       ollama pull qwen2.5:7b
#       ollama pull qwen2.5:1.5b
# 4. Optional custom URL if Ollama is not on localhost:
OLLAMA_BASE_URL=http://localhost:11434

# ── Optional cloud providers (fallback if Ollama unavailable) ─────────────────

# ASI:One
# ASI_ONE_API_KEY=
# ASI1_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Google Gemini free tier
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=
