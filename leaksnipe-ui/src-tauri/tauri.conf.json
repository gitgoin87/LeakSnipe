{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LeakSnipe",
  "version": "0.1.0",
  "identifier": "com.gitgoin87.leaksnipe",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LeakSnipe",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "backgroundColor": "#070b14"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
